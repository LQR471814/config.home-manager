#!/bin/sh

PROGRAM="$1"

if [ -f ~/files/Windows/creds ]; then
	FORM_INPUT=$(cat ~/files/Windows/creds)
else
	FORM_INPUT=$(zenity --forms \
	  --title="Windows VM" \
	  --text="Enter windows credentials" \
	  --add-entry="Username" \
	  --add-password="Password" \
	  --separator="|")
fi

IFS="|" read -r USERNAME PASSWORD <<EOF
$FORM_INPUT
EOF

if [ "$PROGRAM" = "" ]; then
	echo "$USERNAME

$PASSWORD" | xfreerdp /from-stdin /v:127.0.0.1 /cert:tofu /clipboard +dynamic-resolution
else
	echo "$USERNAME

$PASSWORD" | xfreerdp /from-stdin /v:127.0.0.1 /cert:tofu /clipboard +dynamic-resolution "/app:program:$PROGRAM"
fi

